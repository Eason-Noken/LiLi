                document.getElementById('map-section').style.display = 'block';
            } else if (tabName === 'profile') {
                document.getElementById('profile-section').style.display = 'block';
            }
        }

        function getCrowdLevel(crowd) {
            if (crowd < 40) return 'low';
            if (crowd < 70) return 'medium';
            return 'high';
        }

        function getCrowdText(crowd) {
            const level = getCrowdLevel(crowd);
            if (level === 'low') return `低拥挤度 (${crowd}%)`;
            if (level === 'medium') return `中等拥挤度 (${crowd}%)`;
            return `高拥挤度 (${crowd}%)`;
        }

        function getWaitTime(crowd) {
            if (crowd < 40) return '5分钟';
            if (crowd < 70) return '15分钟';
            return '25分钟';
        }

        function renderCanteens() {
            const container = document.getElementById('canteen-status-container');
            container.innerHTML = '';

            canteens.forEach(canteen => {
                const level = getCrowdLevel(canteen.crowd);
                const card = document.createElement('div');
                card.className = 'canteen-card';
                card.innerHTML = `
                    <h3>${canteen.name}</h3>
                    <div class="crowd-level">
                        <div class="crowd-bar">
                            <div class="crowd-fill ${level}" style="width: ${canteen.crowd}%"></div>
                        </div>
                        <div class="crowd-text ${level}">${getCrowdText(canteen.crowd)}</div>
                    </div>
                    <div class="wait-time">预计等待时间：${getWaitTime(canteen.crowd)}</div>
                    <div class="wait-time">推荐指数：${getRatingStars(canteen.crowd)}</div>
                `;
                container.appendChild(card);
            });
        }

        function getRatingStars(crowd) {
            if (crowd < 40) return '⭐⭐⭐⭐⭐';
            if (crowd < 70) return '⭐⭐⭐';
            return '⭐⭐';
        }

        function filterFood(type) {
            const filterBtns = document.querySelectorAll('.filter-btn');
            filterBtns.forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            renderFoodRecommendations(type);
        }

        function renderFoodRecommendations(filterType) {
            const container = document.getElementById('food-recommendations-container');
            container.innerHTML = '';

            let filteredFoods = foods;
            
            if (filterType !== 'all') {
                filteredFoods = foods.filter(f => f.type === filterType);
            }

            if (currentUser && currentUser.foodTypes && currentUser.foodTypes.length > 0 && filterType === 'all') {
                filteredFoods = foods.filter(f => 
                    currentUser.foodTypes.includes(f.type) || 
                    currentUser.tastes.some(t => f.taste.includes(t))
                );
            }

            filteredFoods.forEach(food => {
                const card = document.createElement('div');
                card.className = 'food-card';
                const stars = '⭐'.repeat(Math.round(food.rating));
                card.innerHTML = `
                    <img src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=${food.image}&image_size=square" alt="${food.name}" class="food-image">
                    <div class="food-info">
                        <h3>${food.name}</h3>
                        <div class="food-tags">
                            <span class="food-tag">${food.type}</span>
                            ${food.taste.map(t => `<span class="food-tag">${t}</span>`).join('')}
                        </div>
                        <div class="food-description">供应食堂：${food.canteen}</div>
                        <div class="food-footer">
                            <div class="food-price">¥${food.price.toFixed(2)}</div>
                            <div class="food-rating">
                                <span class="rating-stars">${stars}</span>
                                <span class="rating-count">${food.ratingCount}</span>
                            </div>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function renderMap() {
            const container = document.getElementById('map-markers-container');
            container.innerHTML = '';

            canteens.forEach(canteen => {
                const level = getCrowdLevel(canteen.crowd);
                const marker = document.createElement('div');
                marker.className = 'map-marker';
                marker.style.top = canteen.position.top;
                marker.style.left = canteen.position.left;
                marker.innerHTML = `
                    <div class="marker-icon ${level}">🍽️</div>
                    <div class="marker-tooltip">${canteen.name} (${getCrowdText(canteen.crowd)})</div>
                `;
                container.appendChild(marker);
            });

            dormitories.forEach(dorm => {
                const marker = document.createElement('div');
                marker.className = 'map-marker';
                marker.style.top = dorm.position.top;
                marker.style.left = dorm.position.left;
                marker.innerHTML = `
                    <div class="marker-icon dorm">🏠</div>
                    <div class="marker-tooltip">${dorm.name}宿舍区</div>
                `;
                container.appendChild(marker);
            });
        }

        function updateProfile() {
            if (!currentUser) return;

            document.getElementById('user-name-display').textContent = `欢迎, ${currentUser.name}`;
            document.getElementById('profile-name').textContent = currentUser.name;
            document.getElementById('profile-student-id').textContent = `学号：${currentUser.studentId}`;
            document.getElementById('profile-dorm').textContent = currentUser.dorm || '--';
            document.getElementById('profile-origin').textContent = currentUser.origin || '--';
            document.getElementById('profile-register-time').textContent = currentUser.registerTime || '--';
            document.getElementById('profile-meal-count').textContent = currentUser.mealCount || 0;

            const tastesContainer = document.getElementById('profile-tastes');
            tastesContainer.innerHTML = '';
            if (currentUser.tastes && currentUser.tastes.length > 0) {
                currentUser.tastes.forEach(taste => {
                    const tag = document.createElement('span');
                    tag.className = 'preference-tag';
                    tag.textContent = taste;
                    tastesContainer.appendChild(tag);
                });
            }

            const foodTypesContainer = document.getElementById('profile-food-types');
            foodTypesContainer.innerHTML = '';
            if (currentUser.foodTypes && currentUser.foodTypes.length > 0) {
                currentUser.foodTypes.forEach(type => {
                    const tag = document.createElement('span');
                    tag.className = 'preference-tag category';
                    tag.textContent = type;
                    foodTypesContainer.appendChild(tag);
                });
            }

            const avatar = document.getElementById('profile-avatar');
            avatar.textContent = currentUser.name.charAt(0);
        }

        function editPreferences() {
            if (!currentUser) return;

            selectedDorm = currentUser.dorm || '';
            selectedOrigin = currentUser.origin || '';
            selectedTastes = currentUser.tastes || [];
            selectedFoodTypes = currentUser.foodTypes || [];

            resetOptionSelection('dorm-options', selectedDorm, false);
            resetOptionSelection('origin-options', selectedOrigin, false);
            resetOptionSelection('taste-options', selectedTastes, true);
            resetOptionSelection('food-type-options', selectedFoodTypes, true);

            showPreferences();
        }

        function resetOptionSelection(containerId, selectedValues, isMultiSelect) {
            const container = document.getElementById(containerId);
            const items = container.querySelectorAll('.option-item');
            
            items.forEach(item => {
                item.classList.remove('selected');
                if (isMultiSelect) {
                    if (selectedValues.includes(item.dataset.value)) {
                        item.classList.add('selected');
                    }
                } else {
                    if (item.dataset.value === selectedValues) {
                        item.classList.add('selected');
                    }
                }
            });
        }

        function updateCrowdLevels() {
            canteens.forEach(canteen => {
                const change = (Math.random() - 0.5) * 15;
                canteen.crowd = Math.max(10, Math.min(95, canteen.crowd + change));
            });
            renderCanteens();
            renderMap();
        }

        setInterval(updateCrowdLevels, 30000);

        window.onload = function() {
            const savedUser = localStorage.getItem('currentUser');
            if (savedUser) {
                const parsed = JSON.parse(savedUser);
                const fullUser = localStorage.getItem(`user_${parsed.studentId}_${parsed.phone}`);
                if (fullUser) {
                    currentUser = JSON.parse(fullUser);
                    showMain();
                }
            }
        };
    </script>
</body>
</html>
