        function validateStudentId(id) {
            const regex = /^\d{8,12}$/;
            return regex.test(id);
        }

        function validatePhone(phone) {
            const regex = /^1[3-9]\d{9}$/;
            return regex.test(phone);
        }

        function validateName(name) {
            return name && name.trim().length > 0;
        }

        function handleLogin() {
            const studentId = document.getElementById('login-student-id').value;
            const phone = document.getElementById('login-phone').value;

            let isValid = true;

            if (!validateStudentId(studentId)) {
                document.getElementById('login-student-id').classList.add('error');
                document.getElementById('login-student-id-error').classList.add('show');
                isValid = false;
            } else {
                document.getElementById('login-student-id').classList.remove('error');
                document.getElementById('login-student-id-error').classList.remove('show');
            }

            if (!validatePhone(phone)) {
                document.getElementById('login-phone').classList.add('error');
                document.getElementById('login-phone-error').classList.add('show');
                isValid = false;
            } else {
                document.getElementById('login-phone').classList.remove('error');
                document.getElementById('login-phone-error').classList.remove('show');
            }

            if (isValid) {
                const storedUser = localStorage.getItem(`user_${studentId}_${phone}`);
                if (storedUser) {
                    currentUser = JSON.parse(storedUser);
                    showMain();
                } else {
                    alert('账号不存在，请先注册');
                }
            }
        }

        function handleRegister() {
            const studentId = document.getElementById('register-student-id').value;
            const phone = document.getElementById('register-phone').value;
            const name = document.getElementById('register-name').value;

            let isValid = true;

            if (!validateStudentId(studentId)) {
                document.getElementById('register-student-id').classList.add('error');
                document.getElementById('register-student-id-error').classList.add('show');
                isValid = false;
            } else {
                document.getElementById('register-student-id').classList.remove('error');
                document.getElementById('register-student-id-error').classList.remove('show');
            }

            if (!validatePhone(phone)) {
                document.getElementById('register-phone').classList.add('error');
                document.getElementById('register-phone-error').classList.add('show');
                isValid = false;
            } else {
                document.getElementById('register-phone').classList.remove('error');
                document.getElementById('register-phone-error').classList.remove('show');
            }

            if (!validateName(name)) {
                document.getElementById('register-name').classList.add('error');
                document.getElementById('register-name-error').classList.add('show');
                isValid = false;
            } else {
                document.getElementById('register-name').classList.remove('error');
                document.getElementById('register-name-error').classList.remove('show');
            }

            if (isValid) {
                const existingUser = localStorage.getItem(`user_${studentId}_${phone}`);
                if (existingUser) {
                    alert('该账号已注册，请直接登录');
                } else {
                    currentUser = {
                        studentId,
                        phone,
                        name,
                        registerTime: new Date().toLocaleString()
                    };
                    showPreferences();
                }
            }
        }

        function setupOptionClick(containerId, isMultiSelect, callback) {
            const container = document.getElementById(containerId);
            const items = container.querySelectorAll('.option-item');
            
            items.forEach(item => {
                item.addEventListener('click', function() {
                    const value = this.dataset.value;
                    
                    if (isMultiSelect) {
                        const index = selectedTastes.indexOf(value);
                        if (index > -1) {
                            selectedTastes.splice(index, 1);
                            this.classList.remove('selected');
                        } else {
                            selectedTastes.push(value);
                            this.classList.add('selected');
                        }
                    } else {
                        items.forEach(i => i.classList.remove('selected'));
                        this.classList.add('selected');
                        callback(value);
                    }
                });
            });
        }

        function setupFoodTypeClick() {
            const container = document.getElementById('food-type-options');
            const items = container.querySelectorAll('.option-item');
            
            items.forEach(item => {
                item.addEventListener('click', function() {
                    const value = this.dataset.value;
                    const index = selectedFoodTypes.indexOf(value);
                    if (index > -1) {
                        selectedFoodTypes.splice(index, 1);
                        this.classList.remove('selected');
                    } else {
                        selectedFoodTypes.push(value);
                        this.classList.add('selected');
                    }
                });
            });
        }

        setupOptionClick('dorm-options', false, (value) => { selectedDorm = value; });
        setupOptionClick('origin-options', false, (value) => { selectedOrigin = value; });
        setupOptionClick('taste-options', true);
        setupFoodTypeClick();

        function savePreferences() {
            if (!selectedDorm) {
                alert('请选择所在宿舍区');
                return;
            }
            if (!selectedOrigin) {
                alert('请选择来自哪个地方');
                return;
            }
            if (selectedTastes.length === 0) {
                alert('请选择至少一种喜爱的口味');
                return;
            }
            if (selectedFoodTypes.length === 0) {
                alert('请选择至少一种喜欢的菜品类型');
                return;
            }

            currentUser.dorm = selectedDorm;
            currentUser.origin = selectedOrigin;
            currentUser.tastes = selectedTastes;
            currentUser.foodTypes = selectedFoodTypes;
            currentUser.mealCount = 0;

            localStorage.setItem(`user_${currentUser.studentId}_${currentUser.phone}`, JSON.stringify(currentUser));
            showMain();
        }

        function logout() {
            currentUser = null;
